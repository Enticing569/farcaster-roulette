{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "jsxImportSource": "frog",
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true
  },
  "include": ["api/**/*", "**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules"]
}
